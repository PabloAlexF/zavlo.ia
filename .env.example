# ================================================
# MERCADO PAGO CONFIGURATION (REQUIRED FOR PAYMENTS)
# ================================================
# Get your credentials from: https://www.mercadopago.com.br/developers/panel/credentials
# 
# For TESTING use:
# MERCADOPAGO_ACCESS_TOKEN=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#
# For PRODUCTION use:
# MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

MERCADOPAGO_ACCESS_TOKEN=TEST-your-token-here

# ================================================
# OTHER REQUIRED VARIABLES
# ================================================

# Firebase (get from Firebase Console > Project Settings)
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abcdef

# Redis (optional - for caching)
REDIS_HOST=localhost
REDIS_PORT=6379

# API Configuration
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3000

# JWT Secret (generate a secure random string)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=7d

