{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/.next",
  "framework": "nextjs",
  "installCommand": "cd frontend && npm install",
  "devCommand": "cd frontend && npm run dev",
  "env": {
    "NEXT_PUBLIC_API_URL": "https://api.zavloia.com.br/api/v1"
  },
  "regions": ["gru1"],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.zavloia.com.br/api/:path*"
    }
  ]
}
